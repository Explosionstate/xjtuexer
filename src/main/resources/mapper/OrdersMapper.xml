<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatisplusdemo.mapper.OrdersMapper">

    <resultMap id="BaseResultMap" type="com.example.mybatisplusdemo.model.domain.Orders">
        <id column="course_id" property="id" />
        <result column="coursename" property="name" />
        <result column="user_id" property="userId" />
    </resultMap>

    <resultMap id="withUser" type="com.example.mybatisplusdemo.model.vo.OrdersVO">
        <id column="course_id" property="id" />
        <result column="coursename" property="name" />
        <result column="user_id" property="userId" />
        <association property="user" javaType="com.example.mybatisplusdemo.model.domain.User">
            <id column="uid" property="id" />
            <result column="login_name" property="loginName" />
            <result column="password" property="password" />
            <result column="last_login_time" property="lastLoginTime" />
            <result column="remark" property="remark" />
            <result column="is_deleted" property="deleted" />
            <result column="gmt_created" property="gmtCreated" />
            <result column="gmt_modified" property="gmtModified" />
            <result column="avatar" property="avatar" />
        </association>
    </resultMap>

    <select id="selectVOById" resultMap="withUser">
        SELECT
            o.course_id,
            o.coursename,
            NULL AS user_id,
            NULL AS uid,
            NULL AS login_name,
            NULL AS password,
            NULL AS last_login_time,
            NULL AS remark,
            NULL AS is_deleted,
            NULL AS gmt_created,
            NULL AS gmt_modified,
            NULL AS avatar
        FROM coursevisit o
        WHERE o.course_id = #{id}
    </select>

</mapper>
