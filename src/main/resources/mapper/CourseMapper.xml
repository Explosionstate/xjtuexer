<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatisplusdemo.mapper.CourseMapper">

    <resultMap id="BaseResultMap" type="com.example.mybatisplusdemo.model.domain.Course">
        <id column="course_id" property="courseId" />
        <result column="title" property="title" />
        <result column="teacher_id" property="teacherId" />
        <result column="chapters" property="chapters" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" />
        <result column="materials" property="materials" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" />
        <result column="task_points" property="taskPoints" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" />
        <result column="gmt_created" property="gmtCreated" />
        <result column="gmt_modified" property="gmtModified" />
    </resultMap>

    <select id="selectByIdMy" resultMap="BaseResultMap">
        select * from course where course_id = #{id}
    </select>

    <select id="selectListMy" resultMap="BaseResultMap">
        select * from course
    </select>
</mapper>