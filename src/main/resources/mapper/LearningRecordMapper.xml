<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatisplusdemo.mapper.LearningRecordMapper">

    <resultMap id="BaseResultMap" type="com.example.mybatisplusdemo.model.domain.LearningRecord">
        <id column="record_id" property="recordId" />
        <result column="user_id" property="userId" />
        <result column="course_id" property="courseId" />
        <result column="check_in_time" property="checkInTime" />
        <result column="task_point_id" property="taskPointId" />
        <result column="is_online" property="isOnline" />
        <result column="last_updated" property="lastUpdated" />
    </resultMap>

    <select id="selectListMy" resultType="com.example.mybatisplusdemo.model.domain.LearningRecord">
        select * from learning_record
    </select>
</mapper>
